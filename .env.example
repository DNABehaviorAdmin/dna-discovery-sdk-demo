# DNA Behavior SDK Configuration
# Copy this file to .env and fill in your values
# NEVER commit your .env file to version control

# From your DNA Web App Settings page
VITE_DNA_ACCOUNT_ID=

# From your self-registration URL
VITE_DNA_SELF_REGISTRATION_ID=

# RSA public key provided by DNA Behavior (submit a support ticket)
VITE_DNA_ENCRYPTION_KEY=

# From the DNA Developer Portal
VITE_DNA_SUBSCRIPTION_KEY=
